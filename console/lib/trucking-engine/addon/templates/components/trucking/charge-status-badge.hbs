<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
    {{if (eq this.color 'yellow') 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300'}}
    {{if (eq this.color 'blue')   'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300'}}
    {{if (eq this.color 'green')  'bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300'}}
    {{if (eq this.color 'red')    'bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300'}}
    {{if (eq this.color 'gray')   'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300'}}
    {{if (eq this.color 'orange') 'bg-orange-100 text-orange-700 dark:bg-orange-900 dark:text-orange-300'}}
">{{this.label}}</span>
